{
  "name": "claude-2-mail",
  "version": "0.1.0",
  "description": "Local MCP server for Gmail and Google Calendar",
  "homepage": "https://github.com/omkargs/claude-2-mail",
  "command": "python",
  "args": ["gmail_calendar_mcp.py"],
  "env": {
    "GMAIL_MAIL_CONFIG": "{{GMAIL_MAIL_CONFIG}}"
  },
  "tools": [
    "mail_list",
    "mail_read",
    "mail_search",
    "mail_draft",
    "mail_send",
    "mail_auto_reply",
    "calendar_list",
    "calendar_create",
    "calendar_update"
  ]
}
